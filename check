#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

# Ensure MSVC link.exe wins over Git Bash /usr/bin/link when cargo links test
# binaries. Without this, rustc picks the hardlink utility and fails with
# "missing operand after ' ■'".
for msvc_root in \
  "/c/Program Files/Microsoft Visual Studio/2022/Community/VC/Tools/MSVC" \
  "/c/Program Files (x86)/Microsoft Visual Studio/2022/BuildTools/VC/Tools/MSVC"; do
  if [[ -d "$msvc_root" ]]; then
    msvc_ver=$(ls "$msvc_root" 2>/dev/null | sort -V | tail -1)
    if [[ -n "$msvc_ver" && -x "$msvc_root/$msvc_ver/bin/Hostx64/x64/link.exe" ]]; then
      export PATH="$msvc_root/$msvc_ver/bin/Hostx64/x64:$PATH"
      break
    fi
  fi
done

step() { printf '\n=== %s ===\n' "$1"; }

step "canonical doc set exists"
for f in CLAUDE.md SPEC.md DOCTRINE.md MODES.md BODIES.md PHONEMES.md cartridge.schema.json; do
  if [[ -f "$f" ]]; then
    printf '  %-22s OK\n' "$f"
  else
    printf '  %-22s MISSING\n' "$f"
    exit 1
  fi
done

step "no orphan SHIPPING.md"
if [[ -e SHIPPING.md ]]; then
  echo "  SHIPPING.md still exists (should be BODIES.md)"
  exit 1
fi
echo "  OK"

step "rust workspace check (lib + tests, type-only)"
cargo check --workspace --tests --quiet

step "pyruntime imports"
python -c "import pyruntime, pyruntime.analysis, pyruntime.compiled_v1"
echo "  OK"

step "passthrough null targets (static < -120 dBFS, dynamic < -90 dBFS)"
cargo test -p trench-core --test null_targets --quiet 2>&1 | grep -E "(null peak residual|test result|FAIL)" | sed 's/^/  /'

step "hardware parity null (Talking Hedz, report-only)"
PYTHONPATH=. python tools/parity_null.py 2>&1 | sed 's/^/  /'

step "cartridges validate against schema"
python - <<'PY'
import json, sys
from pathlib import Path
import jsonschema
schema = json.loads(Path("cartridge.schema.json").read_text())
ok = bad = 0
for p in Path("cartridges").rglob("*.json"):
    try:
        d = json.loads(p.read_text())
    except Exception as e:
        print(f"  PARSE FAIL {p}: {e}"); bad += 1; continue
    if not isinstance(d, dict) or d.get("format") != "compiled-v1":
        continue
    try:
        jsonschema.validate(d, schema); ok += 1
    except jsonschema.ValidationError as e:
        print(f"  FAIL {p}: {e.message[:200]}"); bad += 1
print(f"  {ok} compiled-v1 cartridges OK, {bad} failed")
sys.exit(1 if bad else 0)
PY

printf '\nall checks passed\n'
