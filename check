#!/usr/bin/env bash
# Strict errors + strict undefined variables
set -eu

cd "$(dirname "$0")"

# Ensure MSVC link.exe wins over Git Bash /usr/bin/link when cargo links test
# binaries. Without this, rustc picks the hardlink utility and fails with
# "missing operand after ' ■'".
for msvc_root in \
  "/c/Program Files/Microsoft Visual Studio/2022/Community/VC/Tools/MSVC" \
  "/c/Program Files (x86)/Microsoft Visual Studio/2022/BuildTools/VC/Tools/MSVC"; do
  if [[ -d "$msvc_root" ]]; then
    msvc_ver=$(ls "$msvc_root" 2>/dev/null | sort -V | tail -1)
    if [[ -n "$msvc_ver" && -x "$msvc_root/$msvc_ver/bin/Hostx64/x64/link.exe" ]]; then
      export PATH="$msvc_root/$msvc_ver/bin/Hostx64/x64:$PATH"
      break
    fi
  fi
done

# Some Windows bash launches do not inherit the user's cargo bin even though
# PowerShell does. Seed the common locations so the repo-local check can run
# from Git Bash / MSYS without shell-specific handholding.
for cargo_glob in "/c/Users"/*/.cargo/bin "/mnt/c/Users"/*/.cargo/bin; do
  if [[ -d "$cargo_glob" ]]; then
    export PATH="$cargo_glob:$PATH"
  fi
done

CARGO_BIN="$(command -v cargo 2>/dev/null || command -v cargo.exe 2>/dev/null || true)"
if [[ -z "$CARGO_BIN" ]]; then
  CARGO_BIN="cargo"
fi

PYTHON_BIN="$(command -v python 2>/dev/null || command -v python.exe 2>/dev/null || command -v python3 2>/dev/null || true)"
if [[ -z "$PYTHON_BIN" ]]; then
  PYTHON_BIN="python"
fi

step() { printf '\n=== %s ===\n' "$1"; }

# Run a cargo test subcommand with explicit exit-status handling — avoids
# relying on `set -o pipefail` for pipe-safety. Captures stdout+stderr to a
# temp file, checks the cargo exit code, prints only the summary lines on
# success, dumps the tail of the log on failure, and exits non-zero so the
# surrounding `set -e` halts the script.
run_cargo_test() {
  local tmp
  tmp=$(mktemp 2>/dev/null || echo "/tmp/trench-check-$$-$RANDOM.log")
  if "$@" >"$tmp" 2>&1; then
    grep -E "(test result|rust parity:|null peak residual)" "$tmp" | sed 's/^/  /' || true
    rm -f "$tmp"
  else
    local code=$?
    echo "  FAILED (cargo exit $code)"
    tail -40 "$tmp" | sed 's/^/  /'
    rm -f "$tmp"
    exit 1
  fi
}

step "canonical doc set exists"
for f in CLAUDE.md SPEC.md DOCTRINE.md MODES.md BODIES.md PHONEMES.md cartridge.schema.json; do
  if [[ -f "$f" ]]; then
    printf '  %-22s OK\n' "$f"
  else
    printf '  %-22s MISSING\n' "$f"
    exit 1
  fi
done

step "no orphan SHIPPING.md"
if [[ -e SHIPPING.md ]]; then
  echo "  SHIPPING.md still exists (should be BODIES.md)"
  exit 1
fi
echo "  OK"

step "rust workspace check (lib + tests, type-only)"
"$CARGO_BIN" check --workspace --tests --quiet

step "passthrough null targets (static < -120 dBFS, dynamic < -90 dBFS)"
run_cargo_test "$CARGO_BIN" test -p trench-core --test null_targets --quiet

step "P2K parity null (41 entries: 35 raw + 6 calibration_re, hard fail at > -140 dB)"
if ! PYTHONPATH=. "$PYTHON_BIN" tools/parity_null.py 2>&1 | sed 's/^/  /'; then
  echo "  FAILED"
  exit 1
fi

step "rust cascade parity (33 raw skins x 4 corners, hard fail at > -120 dB)"
run_cargo_test "$CARGO_BIN" test -p trench-core --test canonical_parity --release --quiet

step "MorphLP RE dump verifier (sanitized table matches committed dump)"
if ! PYTHONPATH=tools "$PYTHON_BIN" tools/verify_morphlp_re.py 2>&1 | sed 's/^/  /'; then
  echo "  FAILED"
  exit 1
fi

step "rust hedz cascade cross-language parity (4 corners vs python bake)"
run_cargo_test "$CARGO_BIN" test -p trench-core --test hedz_cascade --release --quiet

step "rust engine pills smoke (every cartridges/engine/*.json loads)"
run_cargo_test "$CARGO_BIN" test -p trench-core --test engine_pills --release --quiet

step "rust compile_grid round-trip (2-token limit + loader parity)"
run_cargo_test "$CARGO_BIN" test -p trench-core --test compile_grid_roundtrip --release --quiet

step "rust compile_raw round-trip (raw-stage-v1 -> compiled-v1 loader parity)"
run_cargo_test "$CARGO_BIN" test -p trench-core --test compile_raw_roundtrip --release --quiet

step "rust vowel formant classification (8 ok + 2 known-drift: aw, oo)"
run_cargo_test "$CARGO_BIN" test -p trench-core --test vowel_formants --release --quiet

step "hardware parity (engine vs E-mu P2K captures)"
# First gate in the pyramid that compares against real hardware — every
# other gate verifies internal consistency (Rust-vs-Rust, Python-vs-Python).
# Silently skips when capture WAVs aren't on this machine (they're a
# user-side artifact, not committed to the repo). Fails hard on drift.
if [[ -f "C:/Users/hooki/trenchwork_clean/P2k_013_m0_q0.wav" ]]; then
  if ! "$PYTHON_BIN" tools/hardware_parity_batch.py 2>&1 | sed 's/^/  /'; then
    printf '  hardware parity batch failed\n'; exit 1
  fi
else
  printf '  skipped (capture WAVs not present on this machine)\n'
fi

step "cartridges validate against schema"
"$PYTHON_BIN" - <<'PY'
import json, sys
from pathlib import Path
import jsonschema
schema = json.loads(Path("cartridge.schema.json").read_text())
ok = bad = 0
for p in Path("cartridges").rglob("*.json"):
    try:
        d = json.loads(p.read_text())
    except Exception as e:
        print(f"  PARSE FAIL {p}: {e}"); bad += 1; continue
    if not isinstance(d, dict) or d.get("format") != "compiled-v1":
        continue
    try:
        jsonschema.validate(d, schema); ok += 1
    except jsonschema.ValidationError as e:
        print(f"  FAIL {p}: {e.message[:200]}"); bad += 1
print(f"  {ok} compiled-v1 cartridges OK, {bad} failed")
sys.exit(1 if bad else 0)
PY

printf '\nall checks passed\n'
