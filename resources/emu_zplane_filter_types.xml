  </filter>

  <filter id="P2k_021" order="2-12" category="PROG">
    <name>Morph Designer</name>
    <description>The ultimate in synthesizer filters. Up to six completely programmable filter sections (lowpass, highpass, or EQ) and the ability to morph between two completely different frame settings of the six sections. Twenty-four knobs reduced to just two: Morph and Gain (offset).</description>
    <parameters>
      <morph-controls>frame interpolation across all 6 sections</morph-controls>
      <q-controls>gain offset (±50% frequency shift for HP/LP stages)</q-controls>
    </parameters>
    <programmable>
      <sections>6</sections>
      <section-types>any combination of LP, HP, EQ (per section)</section-types>
      <stage-gain-controls>
        <eq-stage>small knob: gain (-24 to +24 dB), big wheel: gain offset (-24 to +24 dB), sum clipped at 0 or 100</eq-stage>
        <hplp-stage>small knob: Q (0 to 100%), big wheel: Q offset (-50% to +50%), sum clipped at 0 or 100</hplp-stage>
      </stage-gain-controls>
    </programmable>
    <note>This is the filter type used by all 12th-order factory filters and all user MorphDesigner presets in resources/Filter/</note>
  </filter>

