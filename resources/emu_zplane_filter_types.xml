  <!-- ================================================================== -->
  <!-- MORPH DESIGNER ARCHITECTURE                                        -->
  <!-- Documents the shared architecture used by all 12th-order filters   -->
  <!-- and user-programmable Morph Designer presets.                       -->
  <!-- ================================================================== -->

  <morph-designer-architecture>
    <description>
      The Morph Designer is the core of the Z-plane filter engine.
      It provides up to six completely programmable filter sections
      (lowpass, highpass, or EQ) with the ability to morph between
      two completely different frame settings of the six sections.
    </description>

    <section-count>6</section-count>
    <total-poles>12 (2 poles per section × 6 sections)</total-poles>

    <section-types>
      <type id="0">Off (passthrough)</type>
      <type id="1">2-pole Lowpass / Highpass</type>
      <type id="2">2-pole EQ (parametric)</type>
      <type id="3">2-pole Lowpass (alternate recipe)</type>
    </section-types>

    <per-section-parameters>
      <frame name="Lo Morph (A)">
        <freq range="0-127">Frequency at morph = 0%</freq>
        <gain range="0-127">Gain/Q at morph = 0%</gain>
      </frame>
      <frame name="Hi Morph (B)">
        <freq range="0-127">Frequency at morph = 100%</freq>
        <gain range="0-127">Gain/Q at morph = 100%</gain>
      </frame>
    </per-section-parameters>

    <global-parameters>
      <morph range="0-127">Interpolates all 6 sections between Lo and Hi frames</morph>
      <q-offset range="0-127">
        For EQ stages: gain offset (-24 to +24 dB, two controls sum and clip).
        For HP/LP stages: Q offset (-50% to +50% frequency shift).
      </q-offset>
    </global-parameters>

    <firmware-compile>
      <description>
        Each section's (type, freq, gain) triplet at the current morph position
        is compiled to a 5-coefficient DF2T biquad kernel [c0, c1, c2, c3, c4]
        via the firmware's integer math pipeline. The 6 kernels are loaded into
        a 12-stage serial cascade (6 active + 6 passthrough).
      </description>
      <sample-rates>
        <rate hz="44100" index="0" scale="220" base="18"/>
        <rate hz="48000" index="1" scale="220" base="18"/>
        <rate hz="96000" index="2" scale="200" base="4"/>
        <rate hz="192000" index="3" scale="177" base="1"/>
      </sample-rates>
    </firmware-compile>
  </morph-designer-architecture>

